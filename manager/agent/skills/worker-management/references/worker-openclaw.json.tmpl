{
  "gateway": {
    "mode": "local",
    "port": 18799,
    "auth": {
      "token": "${WORKER_GATEWAY_AUTH_TOKEN}"
    },
    "remote": {
      "token": "${WORKER_GATEWAY_AUTH_TOKEN}"
    }
  },

  "channels": {
    "matrix": {
      "enabled": true,
      "homeserver": "${AGENTTEAMS_MATRIX_URL}",
      "accessToken": "${WORKER_MATRIX_TOKEN}",
      "encryption": ${MATRIX_E2EE_ENABLED},
      "dm": {
        "policy": "allowlist",
        "allowFrom": [
          "@manager:${AGENTTEAMS_MATRIX_DOMAIN}",
          "@${AGENTTEAMS_ADMIN_USER}:${AGENTTEAMS_MATRIX_DOMAIN}"
        ]
      },
      "groupPolicy": "allowlist",
      "groupAllowFrom": [
        "@manager:${AGENTTEAMS_MATRIX_DOMAIN}",
        "@${AGENTTEAMS_ADMIN_USER}:${AGENTTEAMS_MATRIX_DOMAIN}"
      ],
      "groups": {
        "*": { "allow": true, "requireMention": true }
      },
      "streaming": "partial",
      "blockStreaming": true
    }
  },

  "models": {
    "mode": "merge",
    "providers": {
      "agentteams-gateway": {
        "baseUrl": "${AGENTTEAMS_AI_GATEWAY_URL}/v1",
        "apiKey": "${WORKER_GATEWAY_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "gpt-5.4",           "name": "gpt-5.4",           "reasoning": true,  "contextWindow": 1050000, "maxTokens": 128000, "input": ["text", "image"] },
          { "id": "gpt-5.3-codex",     "name": "gpt-5.3-codex",     "reasoning": true,  "contextWindow": 400000,  "maxTokens": 128000, "input": ["text", "image"] },
          { "id": "gpt-5-mini",        "name": "gpt-5-mini",        "reasoning": true,  "contextWindow": 400000,  "maxTokens": 128000, "input": ["text", "image"] },
          { "id": "gpt-5-nano",        "name": "gpt-5-nano",        "reasoning": true,  "contextWindow": 400000,  "maxTokens": 128000, "input": ["text", "image"] },
          { "id": "claude-opus-4-6",   "name": "claude-opus-4-6",   "reasoning": true,  "contextWindow": 1000000, "maxTokens": 128000, "input": ["text", "image"] },
          { "id": "claude-sonnet-4-6", "name": "claude-sonnet-4-6", "reasoning": true,  "contextWindow": 1000000, "maxTokens": 64000,  "input": ["text", "image"] },
          { "id": "claude-haiku-4-5",  "name": "claude-haiku-4-5",  "reasoning": true,  "contextWindow": 200000,  "maxTokens": 64000,  "input": ["text", "image"] },
          { "id": "qwen3.5-plus",      "name": "qwen3.5-plus",      "reasoning": true,  "contextWindow": 200000,  "maxTokens": 64000,  "input": ["text", "image"] },
          { "id": "deepseek-chat",     "name": "deepseek-chat",     "reasoning": true,  "contextWindow": 256000,  "maxTokens": 128000, "input": ["text"] },
          { "id": "deepseek-reasoner", "name": "deepseek-reasoner", "reasoning": true,  "contextWindow": 256000,  "maxTokens": 128000, "input": ["text"] },
          { "id": "kimi-k2.5",         "name": "kimi-k2.5",         "reasoning": true,  "contextWindow": 256000,  "maxTokens": 128000, "input": ["text", "image"] },
          { "id": "glm-5",             "name": "glm-5",             "reasoning": true,  "contextWindow": 200000,  "maxTokens": 128000, "input": ["text"] },
          { "id": "MiniMax-M2.7",      "name": "MiniMax-M2.7",      "reasoning": true,  "contextWindow": 200000,  "maxTokens": 128000, "input": ["text"] },
          { "id": "MiniMax-M2.7-highspeed", "name": "MiniMax-M2.7-highspeed", "reasoning": true, "contextWindow": 200000, "maxTokens": 128000, "input": ["text"] },
          { "id": "MiniMax-M2.5",      "name": "MiniMax-M2.5",      "reasoning": true,  "contextWindow": 200000,  "maxTokens": 128000, "input": ["text"] }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "timeoutSeconds": 1800,
      "workspace": "~",
      "model": {
        "primary": "agentteams-gateway/${AGENTTEAMS_DEFAULT_MODEL}"
      },
      "models": {
        "agentteams-gateway/gpt-5.4":           { "alias": "gpt-5.4" },
        "agentteams-gateway/gpt-5.3-codex":     { "alias": "gpt-5.3-codex" },
        "agentteams-gateway/gpt-5-mini":        { "alias": "gpt-5-mini" },
        "agentteams-gateway/gpt-5-nano":        { "alias": "gpt-5-nano" },
        "agentteams-gateway/claude-opus-4-6":   { "alias": "claude-opus-4-6" },
        "agentteams-gateway/claude-sonnet-4-6": { "alias": "claude-sonnet-4-6" },
        "agentteams-gateway/claude-haiku-4-5":  { "alias": "claude-haiku-4-5" },
        "agentteams-gateway/qwen3.5-plus":      { "alias": "qwen3.5-plus" },
        "agentteams-gateway/deepseek-chat":     { "alias": "deepseek-chat" },
        "agentteams-gateway/deepseek-reasoner": { "alias": "deepseek-reasoner" },
        "agentteams-gateway/kimi-k2.5":         { "alias": "kimi-k2.5" },
        "agentteams-gateway/glm-5":             { "alias": "glm-5" },
        "agentteams-gateway/MiniMax-M2.7":      { "alias": "MiniMax-M2.7" },
        "agentteams-gateway/MiniMax-M2.7-highspeed": { "alias": "MiniMax-M2.7-highspeed" },
        "agentteams-gateway/MiniMax-M2.5":      { "alias": "MiniMax-M2.5" }
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "elevatedDefault": "full"
    }
  },

  "tools": {
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "matrix": ["*"]
      }
    }
  },

  "session": {
    "resetByType": {
      "dm":    { "mode": "daily", "atHour": 4 },
      "group": { "mode": "daily", "atHour": 4 }
    }
  },

  "plugins": {
    "load": {
      "paths": ["/opt/openclaw/extensions/matrix"]
    },
    "entries": {
      "matrix": { "enabled": true },
      "memory-core": {
        "enabled": true,
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      }
    }
  }
}
