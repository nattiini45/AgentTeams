# install/defaults.env — shared installation defaults for bash and PowerShell installers.
# Both install/agentteams-install.sh and install/agentteams-install.ps1 source/read this file.
# Override any value via environment variable before running the installer.

# Version fallback when GitHub release API is unreachable
: "${AGENTTEAMS_KNOWN_STABLE_VERSION:=v1.1.2}"

# Host ports (published from embedded controller container)
: "${AGENTTEAMS_PORT_GATEWAY:=18080}"
: "${AGENTTEAMS_PORT_CONSOLE:=18001}"
: "${AGENTTEAMS_PORT_ELEMENT_WEB:=18088}"
: "${AGENTTEAMS_PORT_MANAGER_CONSOLE:=18888}"

# Container internal listen ports (docker -p target side)
AGENTTEAMS_CONTAINER_PORT_GATEWAY=8080
AGENTTEAMS_CONTAINER_PORT_CONSOLE=8001
AGENTTEAMS_CONTAINER_PORT_ELEMENT_WEB=8088
AGENTTEAMS_CONTAINER_PORT_MANAGER_CONSOLE=18888

# Domain defaults (host suffixes; full Matrix domain includes gateway port)
AGENTTEAMS_MATRIX_DOMAIN_HOST_SUFFIX=matrix-local.agentteams.io
AGENTTEAMS_AI_GATEWAY_DOMAIN_DEFAULT=aigw-local.agentteams.io
AGENTTEAMS_FS_DOMAIN_DEFAULT=fs-local.agentteams.io

# Persistence / workspace
: "${AGENTTEAMS_DATA_DIR:=agentteams-data}"
AGENTTEAMS_WORKSPACE_DIR_DEFAULT=~/agentteams-manager

# Worker lifecycle
: "${AGENTTEAMS_WORKER_IDLE_TIMEOUT:=720}"

# Nacos Worker market (import/search defaults)
AGENTTEAMS_NACOS_REGISTRY_URI_DEFAULT=nacos://market.agentteams.io:80/public

# MinIO alias prefix inside embedded stack
AGENTTEAMS_STORAGE_PREFIX_DEFAULT=agentteams/agentteams-storage

# Image repository suffixes under ${AGENTTEAMS_REGISTRY}/higress/
AGENTTEAMS_IMAGE_MANAGER=agentteams-manager
AGENTTEAMS_IMAGE_MANAGER_COPAW=agentteams-manager-copaw
AGENTTEAMS_IMAGE_WORKER=agentteams-worker
AGENTTEAMS_IMAGE_COPAW_WORKER=agentteams-copaw-worker
AGENTTEAMS_IMAGE_HERMES_WORKER=agentteams-hermes-worker
AGENTTEAMS_IMAGE_QWENPAW_WORKER=agentteams-qwenpaw-worker
AGENTTEAMS_IMAGE_EMBEDDED=agentteams-embedded
AGENTTEAMS_IMAGE_CONTROLLER=agentteams-controller

# Feature/version gates
AGENTTEAMS_COPAW_WORKER_MIN_VERSION=v1.0.4
AGENTTEAMS_HERMES_WORKER_MIN_VERSION=v1.1.0
AGENTTEAMS_QWENPAW_WORKER_MIN_VERSION=v1.2.0
AGENTTEAMS_EMBEDDED_MIN_VERSION=v1.1.0

# Interactive installer defaults
: "${AGENTTEAMS_NON_INTERACTIVE:=0}"
: "${AGENTTEAMS_MOUNT_SOCKET:=1}"
: "${AGENTTEAMS_DOCKER_PROXY:=1}"
